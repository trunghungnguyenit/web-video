{
  "name": "web-video",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,magenta \"npm run dev:fe\" \"npm run dev:be\"",
    "dev:fe": "npm run dev --workspace=frontend",
    "dev:be": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "build:fe": "npm run build --workspace=frontend",
    "build:be": "npm run build --workspace=backend",
    "start:fe": "npm run start --workspace=frontend",
    "start:be": "npm run start --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
