PORT=4000
FRONTEND_URL=http://localhost:3000
GEMINI_MODEL=gemini-flash-latest
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Tuỳ chọn — fallback nếu FE không gửi apiKey trong body
ELEVENLABS_API_KEY=

# ── License Key (Supabase Auth UID → HMAC) ─────────────────────────────────
# Lấy tại Supabase Dashboard → Project Settings → API → service_role key (secret, KHÔNG lộ ra frontend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Chuỗi bí mật tự đặt — dùng ký HMAC license key, đổi chuỗi này sẽ làm mọi key cũ mất hiệu lực
LICENSE_SECRET=

# ── Gmail SMTP (Nodemailer) — gửi email License Key ────────────────────────
# GMAIL_USER: địa chỉ Gmail dùng để gửi
# GMAIL_APP_PASSWORD: bật 2FA cho tài khoản Gmail rồi tạo "Mật khẩu ứng dụng" 16 ký tự
# tại https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
